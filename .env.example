# ==============================================================
# Digital Shield Rail Defense — Environment Configuration
# ==============================================================
# Copy to .env and fill in production values
# ==============================================================

# App
ENVIRONMENT=production
DEBUG=false
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-secure-random-string

# FastAPI
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=digital_shield
DB_USER=ds_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_2026
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis (for rate limiting / caching)
REDIS_URL=redis://redis:6379/0

# Auth — API Keys (set unique keys for production)
DS_API_KEY_ADMIN=ds-admin-CHANGE-ME-2026
DS_API_KEY_OFFICER=ds-officer-CHANGE-ME-2026
DS_API_KEY_VIEWER=ds-viewer-CHANGE-ME-2026

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://digitalshield.railway.app

# ML
YOLO_MODEL=yolov8n.pt
ML_DEVICE=auto
ANOMALY_THRESHOLD=0.5

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# Logging
LOG_DIR=/app/logs
AUDIT_DIR=/app/logs/audit
